---
const navLinks = [
  { label: 'About', href: '#about' },
  { label: 'Experience', href: '#experience' },
  { label: 'Projects', href: '#projects' },
  { label: 'Contact', href: '#contact' },
];
---

<header id="nav">
  <nav>
    <a href="#home" class="nav-logo" aria-label="Go to top">
      <span class="logo-bracket">&lt;</span>AM<span class="logo-bracket">/&gt;</span>
    </a>

    <ul class="nav-links" role="list">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="nav-link">{link.label}</a>
        </li>
      ))}
    </ul>

    <a href="/CV_ArturMistiuk.pdf" download class="btn-outline nav-resume" aria-label="Download CV PDF">
      CV
    </a>

    <button class="nav-toggle" aria-label="Toggle mobile menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div class="nav-mobile" aria-hidden="true">
    <ul role="list">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="nav-mobile-link">{link.label}</a>
        </li>
      ))}
      <li>
        <a href="/CV_ArturMistiuk.pdf" download class="btn-primary" style="width:100%; justify-content:center;">
          Download CV
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
  #nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    transition: border-color var(--transition-base);
  }

  nav {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 68px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text-primary);
    text-decoration: none;
    flex-shrink: 0;
    transition: color var(--transition-fast);
  }

  .nav-logo:hover {
    color: var(--color-accent);
  }

  .logo-bracket {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
    margin-left: auto;
  }

  .nav-link {
    display: block;
    padding: 0.4rem 0.75rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-text-primary);
    background: var(--color-bg-elevated);
  }

  .nav-resume {
    flex-shrink: 0;
    font-size: 0.875rem;
    padding: 0.45rem 1rem;
    text-decoration: none;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text-primary);
    border-radius: 2px;
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  .nav-mobile {
    display: none;
    padding: 1rem 1.5rem 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .nav-mobile ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .nav-mobile-link {
    display: block;
    padding: 0.6rem 0.75rem;
    font-size: 1rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .nav-mobile-link:hover {
    color: var(--color-text-primary);
    background: var(--color-bg-elevated);
  }

  @media (max-width: 768px) {
    .nav-links,
    .nav-resume {
      display: none;
    }

    .nav-toggle {
      display: flex;
    }

    .nav-mobile.open {
      display: block;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
  const mobileMenu = document.querySelector('.nav-mobile') as HTMLDivElement;

  toggle?.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    mobileMenu.setAttribute('aria-hidden', String(!isOpen));
  });

  // Close mobile menu when a link is clicked
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
    });
  });
</script>
