      </div>
    </div>

    <div class="hero-photo-wrapper">
      <div class="hero-photo-ring">
        <img
          src="/artur-photo.jpg"
          alt="Photo of Artur Mistiuk"
          class="hero-photo"
          width="280"
          height="280"
          loading="eager"
          onerror="this.style.display='none'"
        />
        <div class="hero-photo-placeholder" aria-hidden="true">AM</div>
      </div>
    </div>
  </div>

  <div class="hero-scroll-hint" aria-hidden="true">
    <span>Scroll</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </div>
</section>

<style>
  .hero-section {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 1.5rem 4rem;
    position: relative;
  }

  .hero-container {
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 4rem;
  }

  .hero-greeting {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
  }

  .hero-name {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 800;
    color: var(--color-text-primary);
    line-height: 1.05;
    margin-bottom: 0.4rem;
    letter-spacing: -0.02em;
  }

  .hero-title {
    font-size: clamp(1.25rem, 3.5vw, 2rem);
    font-weight: 400;
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
    line-height: 1.3;
  }

  .hero-bio {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    max-width: 520px;
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .hero-cta a {
    text-decoration: none;
  }

  .hero-social {
    display: flex;
    gap: 1rem;
  }

  .hero-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--color-text-secondary);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
  }

  .hero-social a:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .hero-photo-wrapper {
    display: flex;
    justify-content: center;
  }

  .hero-photo-ring {
    position: relative;
    width: 338px;
    height: 338px;
    border-radius: 50%;
    background: var(--color-bg-surface);
    border: 2px solid var(--color-border);
    overflow: hidden;
    flex-shrink: 0;
    box-shadow: 0 0 0 4px var(--color-bg-elevated), 0 0 0 6px var(--color-border);
  }

  .hero-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-photo-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3.5rem;
    font-weight: 700;
    font-family: var(--font-mono);
    color: var(--color-accent);
    background: var(--color-bg-surface);
  }

  .hero-photo + .hero-photo-placeholder {
    display: none;
  }
  .hero-photo[style*="display: none"] + .hero-photo-placeholder,
  .hero-photo[style*="display:none"] + .hero-photo-placeholder {
    display: flex;
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-secondary);
    letter-spacing: 0.1em;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  @media (max-width: 768px) {
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2.5rem;
    }

    .hero-content { order: 2; }
    .hero-photo-wrapper { order: 1; }

    .hero-photo-ring {
      width: 180px;
      height: 180px;
      margin: 0 auto;
    }

    .hero-photo-placeholder { font-size: 2.5rem; }

    .hero-bio { margin-left: auto; margin-right: auto; }

    .hero-cta,
    .hero-social { justify-content: center; }

    .hero-scroll-hint { display: none; }
  }
</style>
