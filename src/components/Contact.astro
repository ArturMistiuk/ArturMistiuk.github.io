---
const contactLinks = [
  {
    label: 'GitHub',
    href: 'https://github.com/ArturMistiuk',
    description: 'See my code and open-source projects',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/artur-mistiuk-9a9a31234/',
    description: 'Connect with me professionally',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: 'Email',
    href: 'mailto:mistiuk.artur@gmail.com',
    description: 'mistiuk.artur@gmail.com',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
  },
];
---

<section id="contact">
  <div class="section-container">
    <div class="contact-inner">
      <div class="contact-heading fade-in-up">
        <div class="section-divider"></div>
        <h2 class="section-title">Get In Touch</h2>
        <p class="contact-text">
          I'm open to data analyst/data scientist roles, ML-adjacent positions, and interesting collaborations.
          Based in Stockholm — available for both on-site and remote opportunities.
          Feel free to reach out via email or LinkedIn.
        </p>
        <a href="mailto:mistiuk.artur@gmail.com" class="btn-primary contact-cta">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          Say Hello
        </a>
      </div>

      <div class="contact-links fade-in-up">
        {contactLinks.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith('mailto') ? undefined : '_blank'}
            rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
            class="contact-card card"
            aria-label={`${link.label}: ${link.description}`}
          >
            <span class="contact-card-icon" aria-hidden="true" set:html={link.icon} />
            <div>
              <p class="contact-card-label">{link.label}</p>
              <p class="contact-card-desc">{link.description}</p>
            </div>
          </a>
        ))}

        <a href="/CV_ArturMistiuk.pdf" download class="contact-card card cv-card">
          <span class="contact-card-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="12" y1="18" x2="12" y2="12"/>
              <line x1="9" y1="15" x2="15" y2="15"/>
            </svg>
          </span>
          <div>
            <p class="contact-card-label">CV</p>
            <p class="contact-card-desc">Download PDF</p>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .contact-text {
    font-size: 0.975rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 1.5rem 0 2rem;
    max-width: 440px;
  }

  .contact-cta { text-decoration: none; }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .contact-card:hover {
    border-color: var(--color-accent);
    transform: translateX(4px);
    box-shadow: none;
  }

  .cv-card:hover { border-color: var(--color-accent-green); }

  .contact-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: var(--radius-sm);
    background: var(--color-bg-elevated);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .cv-card .contact-card-icon { color: var(--color-accent-green); }

  .contact-card-label {
    font-size: 0.925rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 0.1rem;
  }

  .contact-card-desc {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
  }

  @media (max-width: 900px) {
    .contact-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .contact-card:hover { transform: translateY(-3px); }
  }
</style>
